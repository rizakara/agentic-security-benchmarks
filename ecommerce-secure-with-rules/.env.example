# Server
PORT=3000
NODE_ENV=production

# PostgreSQL
DATABASE_URL=postgresql://ecommerce:changeme@db:5432/ecommerce

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_ACCESS_SECRET=change-this-to-a-random-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-this-to-another-random-secret-at-least-32-chars

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# CORS
CORS_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5
